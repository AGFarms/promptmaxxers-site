/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains
  Content-Security-Policy: default-src 'self'; script-src 'self' https://cal.com https://*.cal.com https://js.stripe.com https://checkout.stripe.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https://cal.com https://*.cal.com https://js.stripe.com https://checkout.stripe.com; connect-src 'self' https://api.cal.com https://webhook.promptmaxxers.com; font-src 'self' data:; base-uri 'self'; form-action 'self' https://checkout.stripe.com

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/welcome/*
  X-Robots-Tag: noindex
